# CyberNanoPay Contract Deployment

# Wallet mnemonic (24 words)
WALLET_MNEMONIC=

# TEE public key (Ed25519, 64 hex chars)
# Get this from the TEE server: GET /attestation → teePublicKey
TEE_PUBKEY=

# Network: mainnet or testnet
NETWORK=testnet

# TON RPC endpoint (optional, auto-detected from NETWORK)
# TON_RPC=https://testnet.toncenter.com/api/v2/jsonRPC

# USDT Jetton master address (optional — used to auto-detect Jetton wallet)
# Mainnet USDT: EQCxE6mUtQJKFnGfaROTKOt1lZbDiiX1kCixRv7Nw2Id_sDs
# Testnet USDT: kQBqSpvo4S87mX9tjHaG4zhYZeORhVhMapBJpnMZ64jhrP-A
JETTON_MASTER=

# Toncenter API key (optional, avoids rate limiting)
TONCENTER_API_KEY=
