# CyberNanoPay TEE Aggregator

PORT=4030

# TON RPC
TON_RPC=https://toncenter.com/api/v2/jsonRPC

# CyberGateway contract address (after deployment)
GATEWAY_ADDRESS=

# Wallet mnemonic for submitting batch settlement transactions (pays gas)
WALLET_MNEMONIC=

# Admin token for protected endpoints (/flush, /policy, /register-key, /simulate-deposit)
# Leave empty for development (no auth)
ADMIN_TOKEN=

# Telegram bot URL for HITL approval notifications (optional)
TELEGRAM_BOT_URL=

# Toncenter API key (optional, avoids rate limiting on testnet)
TONCENTER_API_KEY=

# TEE Ed25519 seed (32 bytes hex). Optional.
# In Phala Cloud, key is auto-derived from enclave — don't set this.
# Only set for local development with a fixed keypair.
# TEE_SEED=

# SQLite database path (default: ./data/gateway.db)
# DB_PATH=./data/gateway.db
